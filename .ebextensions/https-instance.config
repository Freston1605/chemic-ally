packages:
  yum:
    certbot: []
    openssl: []

container_commands:
  01_get_certificate:
    command: |
      #!/bin/bash
      set -e
      EMAIL=$(/opt/elasticbeanstalk/bin/get-config environment -k LETSENCRYPT_EMAIL 2>/dev/null || echo "")
      if [ -z "$EMAIL" ]; then
        echo "LETSENCRYPT_EMAIL not set; skipping certificate acquisition."
        exit 0
      fi
      DOMAIN="chemic-ally.xyz"
      WWW_DOMAIN="www.chemic-ally.xyz"
      if [ -d "/etc/letsencrypt/live/$DOMAIN" ]; then
        echo "Certificate exists. Attempting renewal..."
        certbot renew --non-interactive --quiet 2>&1 || true
      else
        echo "Obtaining initial certificate via standalone challenge..."
        systemctl stop nginx 2>/dev/null || true
        certbot certonly --standalone \
          --non-interactive \
          --agree-tos \
          --email "$EMAIL" \
          -d "$DOMAIN" -d "$WWW_DOMAIN" \
          --preferred-challenges http \
          --expand 2>&1 || true
        systemctl start nginx 2>/dev/null || true
      fi
    ignoreErrors: true

  02_configure_nginx_ssl:
    command: |
      #!/bin/bash
      set -e
      DOMAIN="chemic-ally.xyz"
      C="/etc/nginx/conf.d/https-redirect.conf"
      if [ -f "/etc/letsencrypt/live/$DOMAIN/fullchain.pem" ]; then
        echo "Writing nginx SSL configuration (with certificate)..."
        echo 'server {' > "$C"
        echo '    listen 80;' >> "$C"
        echo '    server_name chemic-ally.xyz www.chemic-ally.xyz;' >> "$C"
        echo '    return 301 https://$host$request_uri;' >> "$C"
        echo '}' >> "$C"
        echo '' >> "$C"
        echo 'server {' >> "$C"
        echo '    listen 443 ssl http2;' >> "$C"
        echo '    server_name chemic-ally.xyz www.chemic-ally.xyz;' >> "$C"
        echo '' >> "$C"
        echo '    ssl_certificate /etc/letsencrypt/live/chemic-ally.xyz/fullchain.pem;' >> "$C"
        echo '    ssl_certificate_key /etc/letsencrypt/live/chemic-ally.xyz/privkey.pem;' >> "$C"
        echo '' >> "$C"
        echo '    ssl_protocols TLSv1.2 TLSv1.3;' >> "$C"
        echo '    ssl_ciphers HIGH:!aNULL:!MD5;' >> "$C"
        echo '' >> "$C"
        echo '    client_max_body_size 10M;' >> "$C"
        echo '' >> "$C"
        echo '    location / {' >> "$C"
        echo '        proxy_pass http://127.0.0.1:8000;' >> "$C"
        echo '        proxy_set_header Host $host;' >> "$C"
        echo '        proxy_set_header X-Real-IP $remote_addr;' >> "$C"
        echo '        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;' >> "$C"
        echo '        proxy_set_header X-Forwarded-Proto $scheme;' >> "$C"
        echo '    }' >> "$C"
        echo '' >> "$C"
        echo '    location /.well-known/acme-challenge/ {' >> "$C"
        echo '        root /var/app/current/static;' >> "$C"
        echo '    }' >> "$C"
        echo '}' >> "$C"
      else
        echo "No certificate yet. Skipping nginx SSL config (EB default config will serve HTTP)."
        rm -f "$C"
      fi
      systemctl reload nginx 2>/dev/null || systemctl restart nginx 2>/dev/null || true
      echo "nginx configuration applied."
    ignoreErrors: false

  03_setup_renewal_cron:
    command: |
      #!/bin/bash
      set -e
      if ! command -v certbot &>/dev/null; then
        echo "certbot not installed; skipping cron setup."
        exit 0
      fi
      CRON_FILE="/etc/cron.d/certbot-renew"
      echo '# Daily cron job to renew Lets Encrypt certificates' > "$CRON_FILE"
      echo '# Runs at 3:00 AM UTC every day.' >> "$CRON_FILE"
      echo '0 3 * * * root certbot renew --non-interactive --quiet --deploy-hook "systemctl reload nginx" 2>&1 | logger -t certbot-renew || true' >> "$CRON_FILE"
      chmod 644 "$CRON_FILE"
      echo "Certificate renewal cron job installed at $CRON_FILE"
    ignoreErrors: false