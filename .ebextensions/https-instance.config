packages:
  yum:
    python3-certbot-nginx: []

container_commands:
  01_get_certificate:
    # This command pulls the email from your EB Environment Properties
    command: |
      EMAIL=$(/opt/elasticbeanstalk/bin/get-config environment -k LETSENCRYPT_EMAIL)
      sudo certbot --nginx -d chemic-ally.xyz -d www.chemic-ally.xyz --non-interactive --agree-tos --email $EMAIL
    ignoreErrors: true