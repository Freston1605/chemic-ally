option_settings:
  aws:elasticbeanstalk:application:environment:
    DJANGO_SETTINGS_MODULE: "config.settings.production"
  aws:elasticbeanstalk:container:python:
    WSGIPath: config.wsgi:application

container_commands:
   01_migrate:
     command: "cd /var/app/current && /var/app/venv/*/bin/python3 manage.py migrate --noinput"
     leader_only: true
   02_collectstatic:
     command: "cd /var/app/current && /var/app/venv/*/bin/python3 manage.py collectstatic --noinput"
     leader_only: true
