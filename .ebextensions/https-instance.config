container_commands:
  00_install_certbot:
    command: |
      #!/bin/bash
      set -e
      echo "[00] Installing certbot in an isolated virtual environment..."
      
      # Modern OS versions (Amazon Linux 2023) block global pip installs (PEP 668).
      # Creating a dedicated venv prevents deployment failures.
      python3 -m venv /opt/certbot
      /opt/certbot/bin/pip install --upgrade pip
      /opt/certbot/bin/pip install certbot certbot-nginx 2>&1 | tail -5
      
      # Symlink to make certbot available globally
      ln -sf /opt/certbot/bin/certbot /usr/local/bin/certbot
      echo "[00] certbot installation complete."
    ignoreErrors: false

  01_get_certificate:
    command: |
      #!/bin/bash
      set -e

      DOMAIN="chemic-ally.xyz"
      WWW_DOMAIN="www.chemic-ally.xyz"
      LOG_FILE="/var/log/certbot-install.log"

      EMAIL=$(/opt/elasticbeanstalk/bin/get-config environment -k LETSENCRYPT_EMAIL 2>/dev/null || echo "")
      if [ -z "$EMAIL" ]; then
        echo "[01] LETSENCRYPT_EMAIL not set; skipping certificate acquisition." >> "$LOG_FILE"
        exit 0
      fi

      echo "[01] Requesting/Renewing certificate..." >> "$LOG_FILE"

      # Optimization: Using --nginx instead of --standalone for zero-downtime.
      # --keep-until-expiring naturally handles both initial creation and renewals without manual if/else checks.
      certbot certonly --nginx \
        --non-interactive \
        --agree-tos \
        --email "$EMAIL" \
        -d "$DOMAIN" -d "$WWW_DOMAIN" \
        --keep-until-expiring 2>&1 | tee -a "$LOG_FILE" || true
    ignoreErrors: true

  02_configure_nginx_ssl:
    command: |
      #!/bin/bash
      set -e

      DOMAIN="chemic-ally.xyz"
      CERT_DIR="/etc/letsencrypt/live/$DOMAIN"
      NGINX_CONF="/etc/nginx/conf.d/00_https_redirect.conf"
      LOG_FILE="/var/log/certbot-install.log"

      if [ -f "$CERT_DIR/fullchain.pem" ]; then
        echo "[02] Writing nginx SSL configuration..." >> "$LOG_FILE"

        cat > "$NGINX_CONF" << 'NGINXEOF'
# HTTP → HTTPS redirect
server {
    listen 80;
    server_name chemic-ally.xyz www.chemic-ally.xyz;

    location / {
        return 301 https://$host$request_uri;
    }
}

# HTTPS server
server {
    listen 443 ssl http2;
    server_name chemic-ally.xyz www.chemic-ally.xyz;

    ssl_certificate     /etc/letsencrypt/live/chemic-ally.xyz/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/chemic-ally.xyz/privkey.pem;
    ssl_trusted_certificate /etc/letsencrypt/live/chemic-ally.xyz/chain.pem;

    # Performance and Security
    ssl_stapling on;
    ssl_stapling_verify on;
    resolver 8.8.8.8 1.1.1.1 valid=300s;
    resolver_timeout 5s;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305:DHE-RSA-AES128-GCM-SHA256:DHE-RSA-AES256-GCM-SHA384;
    ssl_prefer_server_ciphers off;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 1d;
    ssl_session_tickets off;

    add_header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" always;
    add_header X-Frame-Options SAMEORIGIN always;
    add_header X-Content-Type-Options nosniff always;

    client_max_body_size 10M;

    location / {
        proxy_pass http://127.0.0.1:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 60s;
    }
}
NGINXEOF

      else
        echo "[02] No certificate found. Reverting to default HTTP config." >> "$LOG_FILE"
        rm -f "$NGINX_CONF"
      fi

      if nginx -t 2>/dev/null; then
        systemctl reload nginx 2>/dev/null || systemctl restart nginx 2>/dev/null || true
      else
        echo "[02] ERROR: nginx config test failed — ignoring reload." >> "$LOG_FILE"
      fi
    ignoreErrors: false

  03_setup_renewal_cron:
    command: |
      #!/bin/bash
      set -e

      if ! command -v certbot &>/dev/null; then exit 0; fi

      CRON_FILE="/etc/cron.d/certbot-renew"
      MINUTE=$((RANDOM % 60))
      
      # Use certbot --nginx for renewals to ensure no downtime during cron execution
      cat > "$CRON_FILE" << CRONEOF
SHELL=/bin/bash
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
${MINUTE} 3 * * * root certbot renew --nginx --non-interactive --quiet --post-hook "systemctl reload nginx" >> /var/log/certbot-renew.log 2>&1 || true
CRONEOF

      chmod 644 "$CRON_FILE"
    ignoreErrors: false