packages:
  yum:
    certbot: []
    openssl: []

container_commands:
  01_get_certificate:
    command: |
      #!/bin/bash
      set -e

      EMAIL=$(/opt/elasticbeanstalk/bin/get-config environment -k LETSENCRYPT_EMAIL 2>/dev/null || echo "")
      if [ -z "$EMAIL" ]; then
        echo "ERROR: LETSENCRYPT_EMAIL environment property not set."
        echo "Set it in the EB environment properties under Configuration > Software > Environment Properties."
        exit 1
      fi

      DOMAIN="chemic-ally.xyz"
      WWW_DOMAIN="www.chemic-ally.xyz"

      # Check if cert already exists and is valid for at least 30 days
      if [ -d "/etc/letsencrypt/live/$DOMAIN" ]; then
        echo "Certificate exists. Attempting renewal..."
        certbot renew --non-interactive --quiet 2>&1 || true
      else
        echo "Obtaining initial certificate via standalone challenge..."

        # Stop the proxy (nginx) so certbot can bind port 80/443
        systemctl stop nginx 2>/dev/null || true

        certbot certonly --standalone \
          --non-interactive \
          --agree-tos \
          --email "$EMAIL" \
          -d "$DOMAIN" -d "$WWW_DOMAIN" \
          --preferred-challenges http \
          --expand 2>&1

        # Start nginx again so the SSL config can be validated
        systemctl start nginx 2>/dev/null || true
      fi
    ignoreErrors: false

  02_configure_nginx_ssl:
    command: |
      #!/bin/bash
      set -e

      DOMAIN="chemic-ally.xyz"

      # Only write the SSL config if the certificate exists
      if [ ! -f "/etc/letsencrypt/live/$DOMAIN/fullchain.pem" ]; then
        echo "Certificate not yet obtained; writing fallback HTTP-only config."
        cat > /etc/nginx/conf.d/https-redirect.conf << 'NGINX_CONF'
server {
    listen 80;
    server_name chemic-ally.xyz www.chemic-ally.xyz;
    return 301 https://$host$request_uri;
}
NGINX_CONF
        # Reload nginx so the config takes effect
        systemctl reload nginx 2>/dev/null || systemctl restart nginx 2>/dev/null || true
        exit 0
      fi

      echo "Writing nginx SSL configuration..."

      cat > /etc/nginx/conf.d/https-redirect.conf << 'NGINX_CONF'
server {
    listen 80;
    server_name chemic-ally.xyz www.chemic-ally.xyz;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name chemic-ally.xyz www.chemic-ally.xyz;

    ssl_certificate /etc/letsencrypt/live/chemic-ally.xyz/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/chemic-ally.xyz/privkey.pem;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;

    client_max_body_size 10M;

    location / {
        proxy_pass http://127.0.0.1:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location /.well-known/acme-challenge/ {
        root /var/app/current/static;
    }
}
NGINX_CONF

      # Reload nginx to pick up the new config
      systemctl reload nginx 2>/dev/null || systemctl restart nginx 2>/dev/null || true
      echo "nginx SSL configuration applied."
    ignoreErrors: false

  03_setup_renewal_cron:
    command: |
      #!/bin/bash
      set -e

      # Install a daily cron job to check for certificate renewal.
      # Certificates expire after 90 days; certbot renew only acts on
      # certificates expiring within 30 days, so daily is safe.
      CRON_FILE="/etc/cron.d/certbot-renew"

      cat > "$CRON_FILE" << 'CRON'
# Daily cron job to renew Let's Encrypt certificates
# Runs at 3:00 AM UTC every day.
0 3 * * * root certbot renew --non-interactive --quiet --deploy-hook "systemctl reload nginx" 2>&1 | logger -t certbot-renew || true
CRON

      chmod 644 "$CRON_FILE"
      echo "Certificate renewal cron job installed at $CRON_FILE"
    ignoreErrors: false