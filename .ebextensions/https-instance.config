# =============================================================================
# HTTPS / SSL Configuration via Let's Encrypt (Certbot)
# =============================================================================
# Supports two validation methods:
#   1. DNS-01 via Route 53 (preferred — zero downtime, no port conflicts)
#   2. HTTP-01 standalone fallback (stops nginx briefly during validation)
#
# Future ACM + ALB compatibility:
#   When migrating to ACM + ALB, remove this file and configure the ALB
#   listener with the ACM certificate ARN. The Django production settings
#   (SECURE_PROXY_SSL_HEADER) already support ALB-terminated SSL.
# =============================================================================

container_commands:

  # ─────────────────────────────────────────────────────────────────────
  # 00 — Install certbot + Route 53 plugin
  # ─────────────────────────────────────────────────────────────────────
  00_install_certbot:
    command: |
      set -e
      LOG="/var/log/certbot-install.log"
      echo "[$(date -u '+%Y-%m-%dT%H:%M:%SZ')] [00] Installing certbot..." | tee -a "$LOG"

      # Amazon Linux 2023 blocks global pip installs (PEP 668).
      python3 -m venv /opt/certbot
      /opt/certbot/bin/pip install --upgrade pip
      /opt/certbot/bin/pip install certbot certbot-dns-route53 2>&1 | tail -5

      ln -sf /opt/certbot/bin/certbot /usr/local/bin/certbot
      echo "[$(date -u '+%Y-%m-%dT%H:%M:%SZ')] [00] certbot + Route 53 plugin installed." | tee -a "$LOG"
    ignoreErrors: false

  # ─────────────────────────────────────────────────────────────────────
  # 01 — Grant Route 53 permissions to the EC2 instance profile
  #      Required for DNS-01 validation (certbot-dns-route53)
  # ─────────────────────────────────────────────────────────────────────
  01_route53_policy:
    command: |
      set -e
      LOG="/var/log/certbot-install.log"
      echo "[$(date -u '+%Y-%m-%dT%H:%M:%SZ')] [01] Ensuring Route 53 permissions..." | tee -a "$LOG"

      POLICY_NAME="ChemicAllyCertbotRoute53"

      # Check if inline policy already exists
      CURRENT=$(aws iam get-role-policy \
        --role-name aws-elasticbeanstalk-ec2-role \
        --policy-name "$POLICY_NAME" \
        --region "${AWS_DEFAULT_REGION:-us-east-2}" 2>/dev/null || true)

      if [ -z "$CURRENT" ]; then
        aws iam put-role-policy \
          --role-name aws-elasticbeanstalk-ec2-role \
          --policy-name "$POLICY_NAME" \
          --policy-document '{
            "Version": "2012-10-17",
            "Statement": [
              {
                "Effect": "Allow",
                "Action": [
                  "route53:GetChange",
                  "route53:ListHostedZonesByName",
                  "route53:ListResourceRecordSets"
                ],
                "Resource": "*"
              },
              {
                "Effect": "Allow",
                "Action": [
                  "route53:ChangeResourceRecordSets"
                ],
                "Resource": "arn:aws:route53:::hostedzone/*"
              }
            ]
          }' \
          --region "${AWS_DEFAULT_REGION:-us-east-2}"

        echo "[$(date -u '+%Y-%m-%dT%H:%M:%SZ')] [01] Route 53 policy attached." | tee -a "$LOG"
      else
        echo "[$(date -u '+%Y-%m-%dT%H:%M:%SZ')] [01] Route 53 policy already exists, skipping." | tee -a "$LOG"
      fi
    ignoreErrors: true

  # ─────────────────────────────────────────────────────────────────────
  # 02 — Request / renew certificate (DNS-01 preferred, HTTP-01 fallback)
  # ─────────────────────────────────────────────────────────────────────
  02_get_certificate:
    command: |
      set -e
      DOMAIN="chemic-ally.xyz"
      WWW_DOMAIN="www.chemic-ally.xyz"
      LOG="/var/log/certbot-install.log"
      CERT_DIR="/etc/letsencrypt/live/$DOMAIN"

      EMAIL=$(/opt/elasticbeanstalk/bin/get-config environment -k LETSENCRYPT_EMAIL 2>/dev/null || echo "")
      if [ -z "$EMAIL" ]; then
        echo "[$(date -u '+%Y-%m-%dT%H:%M:%SZ')] [02] LETSENCRYPT_EMAIL not set; skipping." | tee -a "$LOG"
        exit 0
      fi

      # Check if a valid cert already exists (not expiring within 30 days)
      if [ -f "$CERT_DIR/fullchain.pem" ]; then
        EXPIRY=$(openssl x509 -enddate -noout -in "$CERT_DIR/cert.pem" 2>/dev/null | cut -d= -f2)
        if [ -n "$EXPIRY" ]; then
          EXPIRY_EPOCH=$(date -d "$EXPIRY" +%s 2>/dev/null || echo "0")
          NOW_EPOCH=$(date +%s)
          DAYS_LEFT=$(( (EXPIRY_EPOCH - NOW_EPOCH) / 86400 ))
          if [ "$DAYS_LEFT" -gt 30 ]; then
            echo "[$(date -u '+%Y-%m-%dT%H:%M:%SZ')] [02] Certificate valid for ${DAYS_LEFT} more days. Skipping request." | tee -a "$LOG"
            exit 0
          fi
          echo "[$(date -u '+%Y-%m-%dT%H:%M:%SZ')] [02] Certificate expires in ${DAYS_LEFT} days. Renewing..." | tee -a "$LOG"
        fi
      fi

      # Attempt DNS-01 validation via Route 53 (zero downtime)
      echo "[$(date -u '+%Y-%m-%dT%H:%M:%SZ')] [02] Attempting DNS-01 validation via Route 53..." | tee -a "$LOG"
      if certbot certonly \
        --dns-route53 \
        --non-interactive \
        --agree-tos \
        --email "$EMAIL" \
        -d "$DOMAIN" -d "$WWW_DOMAIN" \
        --keep-until-expiring \
        2>&1 | tee -a "$LOG"; then
        echo "[$(date -u '+%Y-%m-%dT%H:%M:%SZ')] [02] DNS-01 certificate acquisition succeeded." | tee -a "$LOG"
      else
        echo "[$(date -u '+%Y-%m-%dT%H:%M:%SZ')] [02] DNS-01 failed, falling back to HTTP-01 standalone..." | tee -a "$LOG"

        # HTTP-01 requires port 80 to be free
        systemctl stop nginx 2>/dev/null || true
        sleep 2

        if certbot certonly \
          --standalone \
          --non-interactive \
          --agree-tos \
          --email "$EMAIL" \
          -d "$DOMAIN" -d "$WWW_DOMAIN" \
          --keep-until-expiring \
          2>&1 | tee -a "$LOG"; then
          echo "[$(date -u '+%Y-%m-%dT%H:%M:%SZ')] [02] HTTP-01 certificate acquisition succeeded." | tee -a "$LOG"
        else
          echo "[$(date -u '+%Y-%m-%dT%H:%M:%SZ')] [02] ERROR: Both DNS-01 and HTTP-01 failed." | tee -a "$LOG"
        fi

        # Always restart nginx after HTTP-01 attempt
        systemctl start nginx 2>/dev/null || true
      fi
    ignoreErrors: true

  # ─────────────────────────────────────────────────────────────────────
  # 03 — Write nginx SSL configuration
  # ─────────────────────────────────────────────────────────────────────
  03_configure_nginx_ssl:
    command: |
      set -e
      DOMAIN="chemic-ally.xyz"
      CERT_DIR="/etc/letsencrypt/live/$DOMAIN"
      NGINX_CONF="/etc/nginx/conf.d/00_https_redirect.conf"
      LOG="/var/log/certbot-install.log"

      if [ -f "$CERT_DIR/fullchain.pem" ]; then
        echo "[$(date -u '+%Y-%m-%dT%H:%M:%SZ')] [03] Writing nginx SSL configuration..." | tee -a "$LOG"

        # HTTP → HTTPS redirect
        cat > "$NGINX_CONF" << 'NGINX_HTTP'
        server {
            listen 80;
            server_name chemic-ally.xyz www.chemic-ally.xyz;

            # Let's Encrypt HTTP-01 challenge must pass through
            location /.well-known/acme-challenge/ {
                root /var/lib/letsencrypt;
            }

            location / {
                return 301 https://$host$request_uri;
            }
        }
        NGINX_HTTP

        # HTTPS server block
        cat >> "$NGINX_CONF" << NGINX_HTTPS
        server {
            listen 443 ssl http2;
            server_name chemic-ally.xyz www.chemic-ally.xyz;

            ssl_certificate     ${CERT_DIR}/fullchain.pem;
            ssl_certificate_key ${CERT_DIR}/privkey.pem;
            ssl_trusted_certificate ${CERT_DIR}/chain.pem;

            # Performance and security
            ssl_stapling on;
            ssl_stapling_verify on;
            resolver 8.8.8.8 1.1.1.1 valid=300s;
            resolver_timeout 5s;
            ssl_protocols TLSv1.2 TLSv1.3;
            ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305:DHE-RSA-AES128-GCM-SHA256:DHE-RSA-AES256-GCM-SHA384;
            ssl_prefer_server_ciphers off;
            ssl_session_cache shared:SSL:10m;
            ssl_session_timeout 1d;
            ssl_session_tickets off;

            # HSTS — Django also sets this; nginx value is authoritative here
            add_header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" always;
            add_header X-Frame-Options SAMEORIGIN always;
            add_header X-Content-Type-Options nosniff always;

            client_max_body_size 10M;

            location / {
                proxy_pass http://127.0.0.1:8000;
                proxy_set_header Host \$host;
                proxy_set_header X-Real-IP \$remote_addr;
                proxy_set_header X-Forwarded-For \$proxy_add_x_forwarded_for;
                proxy_set_header X-Forwarded-Proto \$scheme;
                proxy_read_timeout 60s;
            }
        }
        NGINX_HTTPS

        # Test and reload nginx
        if nginx -t 2>/dev/null; then
          systemctl reload nginx 2>/dev/null || systemctl restart nginx 2>/dev/null || true
          echo "[$(date -u '+%Y-%m-%dT%H:%M:%SZ')] [03] nginx reloaded successfully." | tee -a "$LOG"
        else
          echo "[$(date -u '+%Y-%m-%dT%H:%M:%SZ')] [03] ERROR: nginx config test failed." | tee -a "$LOG"
        fi
      else
        echo "[$(date -u '+%Y-%m-%dT%H:%M:%SZ')] [03] No certificate found. Removing custom SSL config." | tee -a "$LOG"
        rm -f "$NGINX_CONF"
      fi
    ignoreErrors: false

  # ─────────────────────────────────────────────────────────────────────
  # 04 — Setup certbot renewal cron + deploy hook
  #      Uses DNS-01 for renewals (zero downtime, no nginx stop needed)
  # ─────────────────────────────────────────────────────────────────────
  04_setup_renewal:
    command: |
      set -e
      LOG="/var/log/certbot-install.log"
      echo "[$(date -u '+%Y-%m-%dT%H:%M:%SZ')] [04] Setting up certbot renewal..." | tee -a "$LOG"

      if ! command -v certbot &>/dev/null; then
        echo "[$(date -u '+%Y-%m-%dT%H:%M:%SZ')] [04] certbot not found, skipping renewal setup." | tee -a "$LOG"
        exit 0
      fi

      # Create deploy hook — reloads nginx only when cert is actually renewed
      mkdir -p /etc/letsencrypt/renewal-hooks/deploy
      cat > /etc/letsencrypt/renewal-hooks/deploy/reload-nginx.sh << 'HOOK'
      #!/bin/bash
      # This script runs automatically after a successful certbot renewal
      if nginx -t 2>/dev/null; then
        systemctl reload nginx
      fi
      HOOK
      chmod +x /etc/letsencrypt/renewal-hooks/deploy/reload-nginx.sh

      # Daily cron at 3:XX AM (randomized minute to avoid thundering herd)
      # Uses DNS-01 — no need to stop nginx, zero downtime
      CRON_FILE="/etc/cron.d/certbot-renew"
      MINUTE=$((RANDOM % 60))

      cat > "$CRON_FILE" << CRON
      SHELL=/bin/bash
      PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin:${PATH}
      ${MINUTE} 3 * * * root certbot renew --dns-route53 --non-interactive --quiet --deploy-hook /etc/letsencrypt/renewal-hooks/deploy/reload-nginx.sh >> /var/log/certbot-renew.log 2>&1 || true
      CRON
      chmod 644 "$CRON_FILE"

      # Add expiry monitoring — alert via CloudWatch custom metric if cert expires within 14 days
      MONITOR_SCRIPT="/opt/certbot/bin/check-cert-expiry.sh"
      cat > "$MONITOR_SCRIPT" << 'MONITOR'
      #!/bin/bash
      # Check certificate expiry and log warning if within 14 days
      DOMAIN="chemic-ally.xyz"
      CERT="/etc/letsencrypt/live/$DOMAIN/cert.pem"
      LOG="/var/log/certbot-renew.log"

      if [ ! -f "$CERT" ]; then
        echo "[$(date -u '+%Y-%m-%dT%H:%M:%SZ')] CERT_EXPIRY_CHECK: CRITICAL - No certificate found" | tee -a "$LOG"
        exit 1
      fi

      EXPIRY=$(openssl x509 -enddate -noout -in "$CERT" | cut -d= -f2)
      EXPIRY_EPOCH=$(date -d "$EXPIRY" +%s)
      NOW_EPOCH=$(date +%s)
      DAYS_LEFT=$(( (EXPIRY_EPOCH - NOW_EPOCH) / 86400 ))

      if [ "$DAYS_LEFT" -le 0 ]; then
        echo "[$(date -u '+%Y-%m-%dT%H:%M:%SZ')] CERT_EXPIRY_CHECK: CRITICAL - Certificate EXPIRED $((DAYS_LEFT * -1)) days ago" | tee -a "$LOG"
      elif [ "$DAYS_LEFT" -le 14 ]; then
        echo "[$(date -u '+%Y-%m-%dT%H:%M:%SZ')] CERT_EXPIRY_CHECK: WARNING - Certificate expires in ${DAYS_LEFT} days" | tee -a "$LOG"
      else
        echo "[$(date -u '+%Y-%m-%dT%H:%M:%SZ')] CERT_EXPIRY_CHECK: OK - Certificate valid for ${DAYS_LEFT} days" | tee -a "$LOG"
      fi
      MONITOR
      chmod +x "$MONITOR_SCRIPT"

      # Add expiry check to cron (runs daily at 9 AM)
      cat >> "$CRON_FILE" << CRON2
      0 9 * * * root $MONITOR_SCRIPT >> /var/log/certbot-renew.log 2>&1 || true
      CRON2

      echo "[$(date -u '+%Y-%m-%dT%H:%M:%SZ')] [04] Renewal cron and monitoring configured." | tee -a "$LOG"
    ignoreErrors: false
