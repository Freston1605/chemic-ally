# =============================================================================
# User-Supplied Environment Variables
# =============================================================================
# These values must be set by the developer (either in a .env file for local
# development or as environment properties in the hosting service).

# Django secret key used for cryptographic signing.
# Generate a strong key with: python -c "from django.core.management.utils
# import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=changeme

# Set to "True" to enable debug mode, otherwise "False".
DEBUG=False

# Space-separated list of hosts the application can serve.
# Example: localhost 127.0.0.1 .elasticbeanstalk.com chemic-ally.xyz
ALLOWED_HOSTS=localhost 127.0.0.1

# AWS credentials for S3 static/media file storage (production only).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-2

# Optional: Custom CloudFront domain for serving static files.
# AWS_S3_CUSTOM_DOMAIN=

# =============================================================================
# AWS RDS (Elastic Beanstalk — auto-provided, do not set manually)
# =============================================================================
# The variables below are injected automatically by AWS Elastic Beanstalk when
# an RDS database is attached to the environment.  They are listed here for
# reference only and should NOT be added to your .env file or EB environment
# properties — AWS manages them on your behalf.
#
#   RDS_DB_NAME       – PostgreSQL database name
#   RDS_USERNAME      – PostgreSQL username
#   RDS_PASSWORD      – PostgreSQL password
#   RDS_HOSTNAME      – PostgreSQL host (endpoint)
#   RDS_PORT          – PostgreSQL port (typically 5432)