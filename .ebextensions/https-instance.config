# =============================================================================
# HTTPS / SSL Configuration via Let's Encrypt (Certbot)
# =============================================================================
# Supports two validation methods:
#   1. DNS-01 via Route 53 (preferred — zero downtime, no port conflicts)
#   2. HTTP-01 standalone fallback (stops nginx briefly during validation)
#
# Nginx SSL configuration is handled by .platform/hooks/postdeploy/01_configure_nginx_ssl.sh
# which runs AFTER EB's nginx setup completes.
#
# Future ACM + ALB compatibility:
#   When migrating to ACM + ALB, remove this file and configure the ALB
#   listener with the ACM certificate ARN. The Django production settings
#   (SECURE_PROXY_SSL_HEADER) already support ALB-terminated SSL.
# =============================================================================

container_commands:

  # ─────────────────────────────────────────────────────────────────────
  # 00 — Install certbot + Route 53 plugin
  # ─────────────────────────────────────────────────────────────────────
  00_install_certbot:
    command: |
      set -e
      LOG="/var/log/certbot-install.log"
      echo "[$(date -u '+%Y-%m-%dT%H:%M:%SZ')] [00] Installing certbot..." | tee -a "$LOG"

      # Amazon Linux 2023 blocks global pip installs (PEP 668).
      python3 -m venv /opt/certbot
      /opt/certbot/bin/pip install --upgrade pip
      /opt/certbot/bin/pip install certbot certbot-dns-route53 2>&1 | tail -5

      ln -sf /opt/certbot/bin/certbot /usr/local/bin/certbot
      echo "[$(date -u '+%Y-%m-%dT%H:%M:%SZ')] [00] certbot + Route 53 plugin installed." | tee -a "$LOG"
    ignoreErrors: false

  # ─────────────────────────────────────────────────────────────────────
  # 01 — Grant Route 53 permissions to the EC2 instance profile
  #      Required for DNS-01 validation (certbot-dns-route53)
  # ─────────────────────────────────────────────────────────────────────
  01_route53_policy:
    command: |
      set -e
      LOG="/var/log/certbot-install.log"
      echo "[$(date -u '+%Y-%m-%dT%H:%M:%SZ')] [01] Ensuring Route 53 permissions..." | tee -a "$LOG"

      POLICY_NAME="ChemicAllyCertbotRoute53"

      # Check if inline policy already exists
      CURRENT=$(aws iam get-role-policy \
        --role-name aws-elasticbeanstalk-ec2-role \
        --policy-name "$POLICY_NAME" \
        --region "${AWS_DEFAULT_REGION:-us-east-2}" 2>/dev/null || true)

      if [ -z "$CURRENT" ]; then
        aws iam put-role-policy \
          --role-name aws-elasticbeanstalk-ec2-role \
          --policy-name "$POLICY_NAME" \
          --policy-document '{
            "Version": "2012-10-17",
            "Statement": [
              {
                "Effect": "Allow",
                "Action": [
                  "route53:GetChange",
                  "route53:ListHostedZonesByName",
                  "route53:ListResourceRecordSets"
                ],
                "Resource": "*"
              },
              {
                "Effect": "Allow",
                "Action": [
                  "route53:ChangeResourceRecordSets"
                ],
                "Resource": "arn:aws:route53:::hostedzone/*"
              }
            ]
          }' \
          --region "${AWS_DEFAULT_REGION:-us-east-2}"

        echo "[$(date -u '+%Y-%m-%dT%H:%M:%SZ')] [01] Route 53 policy attached." | tee -a "$LOG"
      else
        echo "[$(date -u '+%Y-%m-%dT%H:%M:%SZ')] [01] Route 53 policy already exists, skipping." | tee -a "$LOG"
      fi
    ignoreErrors: true

  # ─────────────────────────────────────────────────────────────────────
  # 02 — Request / renew certificate (DNS-01 preferred, HTTP-01 fallback)
  # ─────────────────────────────────────────────────────────────────────
  02_get_certificate:
    command: |
      set -e
      DOMAIN="chemic-ally.xyz"
      WWW_DOMAIN="www.chemic-ally.xyz"
      LOG="/var/log/certbot-install.log"
      CERT_DIR="/etc/letsencrypt/live/$DOMAIN"

      EMAIL=$(/opt/elasticbeanstalk/bin/get-config environment -k LETSENCRYPT_EMAIL 2>/dev/null || echo "")
      if [ -z "$EMAIL" ]; then
        echo "[$(date -u '+%Y-%m-%dT%H:%M:%SZ')] [02] LETSENCRYPT_EMAIL not set; skipping." | tee -a "$LOG"
        exit 0
      fi

      # Check if a valid cert already exists (not expiring within 30 days)
      if [ -f "$CERT_DIR/fullchain.pem" ]; then
        EXPIRY=$(openssl x509 -enddate -noout -in "$CERT_DIR/cert.pem" 2>/dev/null | cut -d= -f2)
        if [ -n "$EXPIRY" ]; then
          EXPIRY_EPOCH=$(date -d "$EXPIRY" +%s 2>/dev/null || echo "0")
          NOW_EPOCH=$(date +%s)
          DAYS_LEFT=$(( (EXPIRY_EPOCH - NOW_EPOCH) / 86400 ))
          if [ "$DAYS_LEFT" -gt 30 ]; then
            echo "[$(date -u '+%Y-%m-%dT%H:%M:%SZ')] [02] Certificate valid for ${DAYS_LEFT} more days. Skipping request." | tee -a "$LOG"
            exit 0
          fi
          echo "[$(date -u '+%Y-%m-%dT%H:%M:%SZ')] [02] Certificate expires in ${DAYS_LEFT} days. Renewing..." | tee -a "$LOG"
        fi
      fi

      # Attempt DNS-01 validation via Route 53 (zero downtime)
      echo "[$(date -u '+%Y-%m-%dT%H:%M:%SZ')] [02] Attempting DNS-01 validation via Route 53..." | tee -a "$LOG"
      if certbot certonly \
        --dns-route53 \
        --non-interactive \
        --agree-tos \
        --email "$EMAIL" \
        -d "$DOMAIN" -d "$WWW_DOMAIN" \
        --keep-until-expiring \
        2>&1 | tee -a "$LOG"; then
        echo "[$(date -u '+%Y-%m-%dT%H:%M:%SZ')] [02] DNS-01 certificate acquisition succeeded." | tee -a "$LOG"
      else
        echo "[$(date -u '+%Y-%m-%dT%H:%M:%SZ')] [02] DNS-01 failed, falling back to HTTP-01 standalone..." | tee -a "$LOG"

        # HTTP-01 requires port 80 to be free
        systemctl stop nginx 2>/dev/null || true
        sleep 2

        if certbot certonly \
          --standalone \
          --non-interactive \
          --agree-tos \
          --email "$EMAIL" \
          -d "$DOMAIN" -d "$WWW_DOMAIN" \
          --keep-until-expiring \
          2>&1 | tee -a "$LOG"; then
          echo "[$(date -u '+%Y-%m-%dT%H:%M:%SZ')] [02] HTTP-01 certificate acquisition succeeded." | tee -a "$LOG"
        else
          echo "[$(date -u '+%Y-%m-%dT%H:%M:%SZ')] [02] ERROR: Both DNS-01 and HTTP-01 failed." | tee -a "$LOG"
        fi

        # Always restart nginx after HTTP-01 attempt
        systemctl start nginx 2>/dev/null || true
      fi
    ignoreErrors: true
